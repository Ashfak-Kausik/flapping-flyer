    <!-- THORAX (root). Clamped to world for now. Stage 3 -> <freejoint/>.
         Sits 50 mm up so it's clearly above the floor in the viewer. -->
    <body name="thorax" pos="0 0 0.05">

      <!-- main flight mass: thorax block, just below the wing hinges -->
      <geom name="thorax_g" type="ellipsoid" pos="0.001 0 0"
            size="0.0020 0.0012 0.0012" mass="60e-6" material="thorax_mat"/>
      <!-- head: small, forward -->
      <geom name="head_g" type="sphere" pos="0.0040 0 0"
            size="0.0008" mass="3e-6" material="thorax_mat"/>
      <!-- abdomen / tail: long, THIN, LIGHT, trailing aft. Tapered ellipsoid
           reads as an abdomen and gives a little aft area for pitch stability
           at almost no mass cost. -->
      <geom name="tail_g" type="ellipsoid" pos="-0.0055 0 0"
            size="0.0050 0.0006 0.0006" mass="12e-6" material="thorax_mat"/>

      <!-- halteres: tiny nubs just behind the wing bases. Visual now,
           EARMARKED as the future rate sensor. Mass ~0.1 mg each (negligible). -->
      <geom name="haltere_R" type="capsule" fromto="-0.0008 0.0007 0  -0.0016 0.0016 -0.0004"
            size="0.00012" mass="1e-7" material="thorax_mat"/>
      <geom name="haltere_L" type="capsule" fromto="-0.0008 -0.0007 0  -0.0016 -0.0016 -0.0004"
            size="0.00012" mass="1e-7" material="thorax_mat"/>

      <!-- ============ RIGHT WING (extends +y) ============
           shoulder above & right of the thorax centre -->
      <body name="stroke_R" pos="0 0.0010 0.0012">
        <joint name="stroke_R" type="hinge" axis="0 0 1" range="-90 90" armature="1e-8"/>
        <inertial pos="0 0 0" mass="1e-7" diaginertia="1e-13 1e-13 1e-13"/>
        <body name="wing_R" pos="0 0 0">
          <joint name="pitch_R" type="hinge" axis="0 1 0" range="-120 120" armature="1e-8"/>
          <!-- elongated-oval wing: span along y, chord along x, thin in z.
               centre pushed to 0.55*R outboard (higher radial centroid),
               and shifted -c/4 in x so the PITCH AXIS is at the quarter-chord. -->
          <geom name="wing_R_g" type="ellipsoid" pos="-0.000875 0.0066 0"
                size="0.00175 0.0060 0.000025" material="wing_mat"
                mass="1.0e-6"/>
        </body>
      </body>

      <!-- ============ LEFT WING (extends -y) ============ -->
      <body name="stroke_L" pos="0 -0.0010 0.0012">
        <joint name="stroke_L" type="hinge" axis="0 0 1" range="-90 90" armature="1e-8"/>
        <inertial pos="0 0 0" mass="1e-7" diaginertia="1e-13 1e-13 1e-13"/>
        <body name="wing_L" pos="0 0 0">
          <joint name="pitch_L" type="hinge" axis="0 1 0" range="-120 120" armature="1e-8"/>
          <geom name="wing_L_g" type="ellipsoid" pos="-0.000875 -0.0066 0"
                size="0.00175 0.0060 0.000025" material="wing_mat"
                mass="1.0e-6"/>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Position actuators on the four hinges. Gains kept gentle so they are
       stable under implicitfast; Stage 2 may instead PRESCRIBE kinematics. -->
  <actuator>
    <position name="a_stroke_R" joint="stroke_R" kp="0.01" kv="1e-5"/>
    <position name="a_pitch_R"  joint="pitch_R"  kp="0.01" kv="1e-5"/>
    <position name="a_stroke_L" joint="stroke_L" kp="0.01" kv="1e-5"/>
    <position name="a_pitch_L"  joint="pitch_L"  kp="0.01" kv="1e-5"/>
  </actuator>
</mujoco>